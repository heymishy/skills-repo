# .env.example — Required environment variables for the web UI container
# Copy this file to .env and fill in real values (never commit .env to git)

# ── Required ─────────────────────────────────────────────────────────────────

# GitHub OAuth App credentials (create at: https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret

# The OAuth callback URL registered in your GitHub OAuth App settings
# Must match the redirect_uri your OAuth App is configured to accept
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Session encryption secret — minimum 32 characters, cryptographically random
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-strong-random-secret-here

# ── Optional ─────────────────────────────────────────────────────────────────

# GitHub Enterprise Server base URL (ADR-012)
# Leave blank to use github.com. Set for GHE deployments:
# GITHUB_API_BASE_URL=https://ghe.your-organisation.com
GITHUB_API_BASE_URL=

# GitHub repository context for artefact fetching
# GITHUB_REPO_OWNER=your-org-or-username
# GITHUB_REPO_NAME=your-skills-repo
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ── Phase 3 persistence (Neon Postgres + Upstash Redis) ──────────────────────

# Neon free-tier Postgres connection string
# Get from: console.neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Upstash Redis REST API credentials
# Get from: console.upstash.com → your database → REST API tab
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here

# ── Multi-tenancy (Sprint 3–5 beta deployment) ────────────────────────────────

# Comma-separated GitHub org logins allowed to access this deployment
# Leave unset for solo-operator mode (tenantId = GitHub username)
TENANT_ORG_ALLOWLIST=

# Maximum journeys allowed per tenant (HTTP 402 when exceeded)
# Required before opening beta — set to intended per-user cap (e.g. 5)
MAX_JOURNEYS_PER_TENANT=5

# Base path for per-tenant artefact directories on the server
# Example: /app/tenants  (must exist before first beta user logs in)
WUCE_TENANT_ROOT_BASE=

# ── Skill executor provider ───────────────────────────────────────────────────

# Which API provider to use for skill turns (default when unset: anthropic)
# anthropic — Anthropic Messages API (default; requires ANTHROPIC_API_KEY)
# copilot   — GitHub Copilot Chat API (requires GITHUB_TOKEN with copilot scope)
# mock      — offline fixture responses, no API calls (local dev only)
SKILL_EXECUTOR_PROVIDER=anthropic

# Anthropic API key — required when SKILL_EXECUTOR_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Node.js environment ───────────────────────────────────────────────────────

# Node.js environment (production | development)
NODE_ENV=production
